generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LeaveType {
  id    String @id @default(cuid())
  code  String @unique
  label String

  balances LeaveBalance[]
  requests LeaveRequest[]
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  entitlement Float
  remaining   Float
  periodStart DateTime
  periodEnd   DateTime
  updatedAt   DateTime @updatedAt

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, periodStart, periodEnd])
  @@index([employeeId, leaveTypeId])
}

model LeaveRequest {
  id            String   @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  fromDate      DateTime
  toDate        DateTime
  requestedDays Float
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId, createdAt])
}
